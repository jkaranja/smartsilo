// Dealership industry tables — only queried when tenant.industry = DEALERSHIP

model DealerVehicleListing {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  vin         String   @unique
  make        String
  model       String
  year        Int
  mileage     Int?
  askingPrice Decimal? @db.Decimal(12, 2)
  status      String   @default("available")

  deals    DealerSalesDeal[]
  tradeIns DealerTradeIn[]

  @@index([tenantId, status])
}

model DealerSalesDeal {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenantId      String
  buyerName     String
  salePrice     Decimal?  @db.Decimal(12, 2)
  financingType String?
  closedAt      DateTime?

  listing   DealerVehicleListing @relation(fields: [listingId], references: [id])
  listingId String

  @@index([tenantId, closedAt])
}

model DealerTradeIn {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenantId     String
  vin          String
  make         String
  model        String
  year         Int
  offeredValue Decimal? @db.Decimal(12, 2)

  listing   DealerVehicleListing? @relation(fields: [listingId], references: [id])
  listingId String?

  @@index([tenantId])
}
