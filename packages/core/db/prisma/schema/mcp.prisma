enum McpServerType {
  INTERNAL // one per org — provisioned automatically for the org's own extension
  EXTERNAL // third-party MCP servers, either org-wide (added by admin) or personal (added by a user)
}

model McpServer {
  id String @id @default(uuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  url       String
  authToken String?
  scopes    String[] @default([])
  connected Boolean  @default(true)

  // Set for org-level servers (INTERNAL + org-wide EXTERNAL).
  // Null for personal servers.
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  type McpServerType @default(EXTERNAL)

  // OAuth fields — populated after a successful OAuth flow (EXTERNAL servers only).
  // authToken holds the current access token (agent uses this directly, no code change needed).
  // Null until the OAuth flow completes; also null for INTERNAL servers (use session token).
  refreshToken   String? // for renewing authToken without user interaction
  tokenExpiresAt DateTime? // when the current authToken expires — triggers proactive refresh

  // Temporary fields used only during the active OAuth flow — cleared after completion.
  oauthClientId     String? // client_id received from dynamic client registration
  oauthClientSecret String? // client_secret received from dynamic client registration
  codeVerifier      String? // PKCE verifier — stored between /authorize redirect and /callback
  discoveryState    Json? // cached RFC 9728 discovery result — avoids re-discovering on each connect
  tools             Json[]  @default([]) // cached tool list from the server — populated on registration, avoids live connection on agent startup
  manifest          Json? // cached extension manifest (capabilities->tool domains, etc. INTERNAL servers only)

  // Set for personal servers — this server is scoped to a single user, not the whole org.
  // Null for org-level servers.
  user   User?   @relation("UserMcpServers", fields: [userId], references: [id])
  userId String?

  // Audit trail — who added this server (applies to org-wide EXTERNAL and personal servers).
  // Null for INTERNAL servers (provisioned automatically, not added by a user).
  addedBy   User?   @relation("OrganizationMcpServers", fields: [addedById], references: [id])
  addedById String?

  @@index([organizationId])
  @@index([organizationId, type])
  @@index([userId])
}
