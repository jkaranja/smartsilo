model User {
  // better-auth
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // custom
  sessions Session[]
  accounts Account[]

  organizationMemberships OrganizationMembership[]

  auditLogs          AuditLog[]
  assignedWorkOrders GarageWorkOrder[]   @relation("AssignedMechanic")
  clinicAppointments ClinicAppointment[] @relation("AttendingPhysician")
  agentConversations AgentThread[]

  userMcpServers         McpServer[] @relation("UserMcpServers")
  organizationMcpServers McpServer[] @relation("OrganizationMcpServers")

  oauthClients       OauthClient[]
  oauthRefreshTokens OauthRefreshToken[]
  oauthAccessTokens  OauthAccessToken[]
  oauthConsents      OauthConsent[]
  ssoProviders       SsoProvider[]

  sentInvitations    OrganizationInvitation[] @relation("sentInvitations")
  repliedInvitations OrganizationInvitation[] @relation("repliedInvitations")
}

model Session {
  // better-auth
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // custom
  oauthRefreshTokens OauthRefreshToken[]
  oauthAccessTokens  OauthAccessToken[]
}

model Account {
  // better-auth
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  // better-auth
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
