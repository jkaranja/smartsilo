enum MessageRole {
  USER
  ASSISTANT
}

model AgentThread {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  // "general" = General thread; capability id (e.g. "orders") = focused thread
  context       String    @default("general")
  lastBriefedAt DateTime?

  messages AgentThreadMessage[]

  @@unique([organizationId, userId, context])
  @@index([organizationId])
  @@index([userId])
}

model AgentThreadMessage {
  id        String      @id @default(uuid())
  createdAt DateTime    @default(now())
  role      MessageRole
  content   Json

  thread   AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId String

  @@index([threadId])
}
