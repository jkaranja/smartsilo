# Based on https://raw.githubusercontent.com/github/gitignore/main/Node.gitignore

# Logs
logs
_.log
npm-debug.log_
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Dependency directories
node_modules/

jspm_packages/
.npm
.node_repl_history
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.\*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# Runtime data
pids
_.pid
_.seed
\*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
\*.lcov
.nyc_output

# TypeScript cache
\*.tsbuildinfo

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Output
\*.tgz
.wrangler

# dotenv environment variable files
.envs
.env*
*.env

generated/
.vscode/

src-trpc-example
src-prisma-example

# temp files
.cache/
.cache
dist
build
.temp

# IDEs
.idea
.vscode-test
.vscode

# Finder (MacOS) folder config
.DS_Store

# code generation
.generated/



# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

